# Production environment for the droplet. Copy to `.env` on the server.
# NEVER commit the real `.env`.

# The image CI pushed to GHCR (used by docker-compose.prod.yml).
API_IMAGE=ghcr.io/CHANGE_ME/mlops-churn-prediction:latest

# Inside the compose network the API talks to the mlflow service by name.
MLFLOW_TRACKING_URI=http://mlflow:5000
REGISTERED_MODEL_NAME=churn-classifier

# Grafana admin password (change it!).
GRAFANA_PASSWORD=change-me-please
