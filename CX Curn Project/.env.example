# Copy this file to `.env` and adjust values as needed.
# `.env` is git-ignored so your real config/secrets never get committed.

# --- MLflow ---
# Phase 2: SQLite backend so the Model Registry works. In a later phase we point
# this at an MLflow server on a DigitalOcean droplet, e.g.
#   MLFLOW_TRACKING_URI=http://<droplet-ip>:5000
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=churn-prediction
# Registered model name the API will load as "Production".
REGISTERED_MODEL_NAME=churn-classifier

# --- Paths / artifacts ---
MODEL_DIR=models

# --- Reproducibility ---
RANDOM_STATE=42
