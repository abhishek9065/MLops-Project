{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Churn API Monitoring",
  "uid": "churn-api",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(churn_http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (s) by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(churn_http_request_latency_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx %)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "100 * sum(rate(churn_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(churn_http_requests_total[5m])), 1)",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total predictions",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        { "expr": "sum(churn_predictions_total)", "legendFormat": "predictions" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Predicted churn share (%)",
      "description": "Fraction of predictions labelled churn. A sudden jump can signal data drift.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "100 * sum(rate(churn_predictions_by_label_total{label=\"churn\"}[5m])) / clamp_min(sum(rate(churn_predictions_by_label_total[5m])), 1)",
          "legendFormat": "churn %"
        }
      ]
    }
  ]
}
