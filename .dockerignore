# Keep the build context small & the image clean. Anything listed here is NOT
# sent to the Docker daemon or copied into the image.

# Virtual environments
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/

# Local ML state (the container generates/serves its own)
mlruns/
mlartifacts/
mlflow.db
models/*.pkl
models/*.json
data/raw/*.csv
data/processed/*

# Dev tooling
.git/
.github/
tests/
notebooks/
docs/
.pytest_cache/
.env
*.md
