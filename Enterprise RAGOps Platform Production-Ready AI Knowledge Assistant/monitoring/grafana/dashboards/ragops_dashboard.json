{
  "title": "Enterprise RAGOps Platform",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Total API Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(ragops_requests_total)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ragops_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Latency p95",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ragops_llm_latency_seconds_bucket[5m])) by (le, llm_model))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Usage",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(ragops_token_usage_total[5m])) by (token_type, llm_model)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Estimated Cost",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "sum(ragops_estimated_cost_usd_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Last Feedback Score",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "ragops_last_feedback_score",
          "refId": "A"
        }
      ]
    }
  ]
}
